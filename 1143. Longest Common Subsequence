class Solution(object):
    def longestCommonSubsequence(self, text1, text2):
        n=len(text1)
        m=len(text2)
        dp={}
        def LCS(i,j):
            if i==n or j==m:
                return 0
            if (i,j) in dp:
                return dp[(i,j)]
            if text1[i]==text2[j]:
                dp[(i,j)]=1+LCS(i+1,j+1)
            else:
                dp[(i,j)]= max(LCS(i+1,j),LCS(i,j+1))
            return dp[(i,j)]
        return LCS(0,0)
